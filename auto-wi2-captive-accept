#!/bin/zsh
set -euo pipefail

PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
APP_DIR="${HOME}/.local/share/auto-wi2-captive-accept"
CONFIG_FILE="${HOME}/.config/auto-wi2-captive-accept/config"
LOG_FILE="${HOME}/Library/Logs/auto-wi2-captive-accept.log"
STATUS_FILE="${HOME}/Library/Logs/auto-wi2-captive-accept.status"
LAST_PORTAL_FILE="${HOME}/Library/Logs/auto-wi2-captive-accept.last-url"
LAST_REFRESH_FILE="${HOME}/Library/Logs/auto-wi2-captive-accept.last-refresh"
LAST_BROWSER_RESULT_FILE="${HOME}/Library/Logs/auto-wi2-captive-accept.last-browser-result.json"
BROWSER_CAPTURE_DIR="${HOME}/Library/Logs/auto-wi2-captive-accept-captures"
TARGET_SSIDS=("DOUTOR_FREE_Wi-Fi" "at_STARBUCKS_Wi2" "Wi2_Free" "Wi2free" "Wi2" "tullys_Wi-Fi")
TARGET_HOSTS=("service.wi2.ne.jp" "10[.]1[.]1[.]100")
CAPTIVE_CHECK_URL="http://captive.apple.com/hotspot-detect.html"
GENERAL_CHECK_URL="http://example.com/"
GSTATIC_CHECK_URL="http://connectivitycheck.gstatic.com/generate_204"
CAPTIVE_PROBE_URLS=("${CAPTIVE_CHECK_URL}" "${GENERAL_CHECK_URL}" "${GSTATIC_CHECK_URL}")
DEFAULT_USEN_LOCAL_PORTAL="http://10.1.1.100:41873/captive/?url=captive.apple.com/hotspot-detect.html"
BROWSER_ACCEPT_HELPER="${APP_DIR}/auto-wi2-browser-accept.js"
PORTAL_DETECTED=0
PORTAL_LOCATION=""
DIRECT_ACCEPTED=0
REFRESHED_SAVED_LOGIN=0
UNSUPPORTED_CAPTIVE=0
BROWSER_RESULT="not_attempted"
# Notifications are attributed to a tiny "Wi2 Auto-Connect.app" (built by install.sh)
# so Notification Center shows a proper name + Wi-Fi icon instead of "terminal-notifier".
NOTIFY_GROUP="wi2-auto-connect"
NOTIFY_SENDER="com.${USER:-$(id -un)}.wi2autoconnect"
# Click target for the latest notification. Wi2 Auto-Connect.app reads this on
# launch (the notification click activates it) and opens the URL.
CLICK_URL_FILE="${HOME}/Library/Logs/auto-wi2-captive-accept.click-url"

timestamp() {
  date "+%Y-%m-%d %H:%M:%S"
}

load_config() {
  if [[ -f "${CONFIG_FILE}" ]]; then
    set -a
    source "${CONFIG_FILE}"
    set +a
  fi
}

log() {
  print -r -- "[$(timestamp)] $*" >> "${LOG_FILE}"
}

status() {
  print -r -- "time=$(timestamp)"
  print -r -- "ssid=${SSID:-unknown}"
  print -r -- "result=$1"
  if [[ $# -gt 1 ]]; then
    print -r -- "detail=$2"
  fi
  return 0
}

write_status() {
  status "$@" > "${STATUS_FILE}"
}

# notify <state> [detail]
#   state: progress | success | fail
# A single grouped notification updates in place: the "progress" toast is
# replaced by the "success"/"fail" result for the same connection attempt.
notify() {
  local state="$1"
  local detail="${2:-}"
  # Clicking the notification (or its "Show" button) opens this URL. Defaults to
  # the detected captive portal so the user can finish/inspect the sign-in by hand.
  # The click activates Wi2 Auto-Connect.app, which opens whatever is recorded here.
  local click_url="${3:-${PORTAL_LOCATION:-}}"
  local title body sound subtitle
  subtitle="${SSID:-}"
  if [[ -n "${click_url}" ]]; then
    print -r -- "${click_url}" > "${CLICK_URL_FILE}" 2>/dev/null || true
  else
    rm -f "${CLICK_URL_FILE}" 2>/dev/null || true
  fi
  case "${state}" in
    progress)
      title="Connecting to Wi-Fi…"
      body="${detail:-Clearing the Wi2 captive portal…}"
      sound=""
      ;;
    success)
      title="Wi-Fi Connected"
      body="${detail:-Captive portal cleared automatically.}"
      sound="Glass"
      ;;
    *)
      title="Wi-Fi needs a hand"
      body="${detail:-Could not clear the captive portal automatically.}"
      sound="Basso"
      ;;
  esac

  if command -v terminal-notifier >/dev/null 2>&1; then
    local args=(-title "${title}" -message "${body}" -group "${NOTIFY_GROUP}" -sender "${NOTIFY_SENDER}")
    if [[ -n "${subtitle}" ]]; then args+=(-subtitle "${subtitle}"); fi
    if [[ -n "${sound}" ]]; then args+=(-sound "${sound}"); fi
    terminal-notifier "${args[@]}" >/dev/null 2>&1 || true
  else
    local osa="display notification \"${body}\" with title \"${title}\""
    if [[ -n "${subtitle}" ]]; then osa="${osa} subtitle \"${subtitle}\""; fi
    if [[ -n "${sound}" ]]; then osa="${osa} sound name \"${sound}\""; fi
    osascript -e "${osa}" >/dev/null 2>&1 || true
  fi
}

captive_check_success() {
  local body
  body="$(mktemp -t auto-wi2-success.XXXXXX)"
  if curl --silent --show-error --connect-timeout 3 --max-time 8 \
    --output "${body}" \
    "${CAPTIVE_CHECK_URL}" >/dev/null 2>&1 \
    && grep -q "<BODY>Success</BODY>" "${body}"; then
    rm -f "${body}"
    return 0
  fi
  rm -f "${body}"
  return 1
}

http_status_from_headers() {
  awk 'toupper($1) ~ /^HTTP/ { code=$2 } END { print code }' "$1"
}

internet_probe_success() {
  local url="$1"
  local expected="$2"
  local headers body http_status

  headers="$(mktemp -t auto-wi2-internet-headers.XXXXXX)"
  body="$(mktemp -t auto-wi2-internet-body.XXXXXX)"
  if ! curl --silent --show-error --connect-timeout 3 --max-time 8 \
    --dump-header "${headers}" \
    --output "${body}" \
    "${url}" >/dev/null 2>&1; then
    rm -f "${headers}" "${body}"
    return 1
  fi

  http_status="$(http_status_from_headers "${headers}")"
  case "${expected}" in
    example)
      if [[ "${http_status}" == "200" ]] && grep -qi "Example Domain" "${body}"; then
        rm -f "${headers}" "${body}"
        return 0
      fi
      ;;
    gstatic)
      if [[ "${http_status}" == "204" ]]; then
        rm -f "${headers}" "${body}"
        return 0
      fi
      ;;
  esac

  rm -f "${headers}" "${body}"
  return 1
}

general_internet_check_success() {
  internet_probe_success "${GENERAL_CHECK_URL}" "example" \
    || internet_probe_success "${GSTATIC_CHECK_URL}" "gstatic"
}

online_check_success() {
  if ! captive_check_success; then
    return 1
  fi

  if network_is_possible_target "${SSID:-}" "${WIFI_IP:-}" && ! general_internet_check_success; then
    log "Apple captive check passed, but general internet probes failed on a target-like network. Treating as captive. ssid=${SSID:-unknown} ip=${WIFI_IP:-unknown}"
    return 1
  fi

  return 0
}

wifi_device() {
  networksetup -listallhardwareports 2>/dev/null | awk '
    /Hardware Port: Wi-Fi|Hardware Port: AirPort/ {
      getline
      if ($1 == "Device:") print $2
    }
  ' | head -n 1
}

current_ssid() {
  local device
  device="$(wifi_device)"
  [[ -n "${device}" ]] || return 0
  networksetup -getairportnetwork "${device}" 2>/dev/null \
    | sed -E 's/^Current Wi-Fi Network: //; s/^You are not associated with an AirPort network\.//'
}

current_wifi_ip() {
  local device
  device="$(wifi_device)"
  [[ -n "${device}" ]] || return 0
  ifconfig "${device}" 2>/dev/null | awk '$1 == "inet" { print $2; exit }'
}

ssid_is_target() {
  local ssid="$1"
  local target
  for target in "${TARGET_SSIDS[@]}"; do
    [[ "${ssid}" == "${target}" ]] && return 0
  done
  return 1
}

network_is_possible_target() {
  local ssid="$1"
  local ip="$2"

  if [[ -n "${ssid}" ]] && ssid_is_target "${ssid}"; then
    return 0
  fi

  # Captive portals can hide the SSID from networksetup. Observed ranges:
  # DOUTOR/Wi2: 10.68.x.x; Starbucks/Wi2: 10.18.x.x; Tully's/USEN:
  # 10.1.1.x portal-side addresses and 192.168.151.x client-side leases.
  if [[ -z "${ssid}" && ( "${ip}" == 10.68.* || "${ip}" == 10.18.* || "${ip}" == 10.1.1.* || "${ip}" == 192.168.151.* ) ]]; then
    return 0
  fi

  return 1
}

target_regex() {
  local IFS="|"
  print -r -- "DOUTOR_FREE_Wi-Fi|at_STARBUCKS_Wi2|tullys_Wi-Fi|TULLY|Wi2 Free Wi-Fi Service|USEN Free Wi-Fi|USEN CORPORATION|${TARGET_HOSTS[*]}"
}

portal_is_usen_local() {
  local location="$1"
  [[ "${location}" == http://10.1.1.100:* || "${location}" == http://10.1.1.100/* ]]
}

saved_usen_local_portal() {
  local location

  [[ -f "${LAST_PORTAL_FILE}" ]] || return 1
  location="$(cat "${LAST_PORTAL_FILE}" 2>/dev/null || true)"
  portal_is_usen_local "${location}" || return 1
  print -r -- "${location}"
}

usen_local_portal_fallback() {
  if saved_usen_local_portal; then
    return 0
  fi

  if [[ "${WIFI_IP:-}" == 192.168.151.* || "${WIFI_IP:-}" == 10.1.1.* ]]; then
    print -r -- "${DEFAULT_USEN_LOCAL_PORTAL}"
    return 0
  fi

  return 1
}

json_escape() {
  print -r -- "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

normalize_usen_gender() {
  local gender_value normalized_gender
  gender_value="$1"
  normalized_gender="$(print -r -- "${gender_value}" | tr '[:upper:]' '[:lower:]')"

  case "${normalized_gender}" in
    f|female|woman|women|*女性*)
      print -r -- "female"
      ;;
    n/a|na|none|etc|other|unknown|*指定なし*)
      print -r -- "etc"
      ;;
    *)
      print -r -- "male"
      ;;
  esac
}

usen_direct_accept() {
  local location="$1"
  local origin stamac birth_year gender_value payload response_file http_code response_text

  portal_is_usen_local "${location}" || return 1

  origin="${location%%/captive/*}"
  [[ -n "${origin}" && "${origin}" != "${location}" ]] || return 1

  stamac="$(print -r -- "${location}" | sed -n 's/.*[?&]stamac=\([^&]*\).*/\1/p')"
  [[ -n "${stamac}" ]] || stamac="00:00:00:00:00:00"

  birth_year="${AUTO_WI2_BIRTH_YEAR:-1990}"
  if [[ ! "${birth_year}" =~ '^[0-9]{4}$' ]]; then
    birth_year="1990"
  fi
  gender_value="$(normalize_usen_gender "${AUTO_WI2_GENDER:-Male}")"

  payload="{\"gender\":\"$(json_escape "${gender_value}")\",\"birth\":\"$(json_escape "${birth_year}")\",\"macaddr\":\"$(json_escape "${stamac}")\",\"lang\":\"en\"}"
  response_file="$(mktemp -t auto-wi2-usen-api.XXXXXX)"

  http_code="$(curl --silent --show-error --connect-timeout 3 --max-time 10 \
    --output "${response_file}" \
    --write-out "%{http_code}" \
    --header "Content-Type: application/json;charset=UTF-8" \
    --data "${payload}" \
    "${origin}/capi/welcome" 2>/dev/null || true)"
  response_text="$(cat "${response_file}" 2>/dev/null || true)"
  rm -f "${response_file}"

  if [[ "${http_code}" == "200" ]] && [[ "${response_text}" == *"ok"* || "${response_text}" == *"success"* ]]; then
    log "Tully's/USEN local portal API accepted demographics. ssid=${SSID:-unknown} location=${location} response=${response_text}"
    sleep 3
    if online_check_success; then
      DIRECT_ACCEPTED=1
      write_status "usen_api_success" "${location}"
      notify success
      return 0
    fi
    log "Tully's/USEN local portal API returned success but network still looks captive. ssid=${SSID:-unknown} location=${location}"
  else
    log "Tully's/USEN local portal API failed. ssid=${SSID:-unknown} location=${location} http_code=${http_code:-none} response=${response_text}"
  fi

  return 1
}

captive_window_is_running() {
  pgrep -x "Captive Network Assistant" >/dev/null 2>&1 \
    || pgrep -x "CaptiveNetworkAssistant" >/dev/null 2>&1
}

wait_for_captive_window() {
  local max_wait="$1"
  local waited=0
  while [[ "${waited}" -lt "${max_wait}" ]]; do
    if captive_window_is_running; then
      return 0
    fi
    sleep 1
    waited=$((waited + 1))
  done
  captive_window_is_running
}

open_native_portal() {
  local location="$1"
  open -b "com.apple.CaptiveNetworkAssistant" "${location}" >/dev/null 2>&1 \
    || open -a "Captive Network Assistant" "${location}" >/dev/null 2>&1 \
    || open "${location}" >/dev/null 2>&1 \
    || true
}

open_portal_if_needed() {
  local response_headers response_body location pattern response_matches_target probe_url response_available saved_location
  response_headers="$(mktemp -t auto-wi2-headers.XXXXXX)"
  response_body="$(mktemp -t auto-wi2-body.XXXXXX)"
  pattern="$(target_regex)"
  location=""
  response_available=0
  response_matches_target=0

  for probe_url in "${CAPTIVE_PROBE_URLS[@]}"; do
    : > "${response_headers}"
    : > "${response_body}"
    if ! curl --silent --show-error --connect-timeout 3 --max-time 8 \
      --dump-header "${response_headers}" \
      --output "${response_body}" \
      "${probe_url}" >/dev/null 2>&1; then
      continue
    fi

    response_available=1
    if grep -Eiq "${pattern}" "${response_headers}" "${response_body}"; then
      response_matches_target=1
    fi

    location="$(awk 'tolower($1) == "location:" { sub(/\r$/, "", $2); print $2; exit }' "${response_headers}")"
    if [[ "${response_matches_target}" == "1" || -n "${location}" ]]; then
      break
    fi
  done

  if [[ "${response_available}" != "1" ]]; then
    if network_is_possible_target "${SSID}" "${WIFI_IP}" && saved_location="$(usen_local_portal_fallback)"; then
      location="${saved_location}"
      response_matches_target=1
      log "Captive probes did not return a response on a target-like network. Using Tully's/USEN local portal fallback. ssid=${SSID:-unknown} ip=${WIFI_IP:-unknown} location=${location}"
    else
      rm -f "${response_headers}" "${response_body}"
      return 0
    fi
  fi

  if [[ -z "${location}" ]] && network_is_possible_target "${SSID}" "${WIFI_IP}" && saved_location="$(usen_local_portal_fallback)"; then
    location="${saved_location}"
    response_matches_target=1
    log "Captive probes did not expose a redirect on a target-like network. Using Tully's/USEN local portal fallback. ssid=${SSID:-unknown} ip=${WIFI_IP:-unknown} location=${location}"
  fi

  if [[ "${response_matches_target}" != "1" ]] && ! network_is_possible_target "${SSID}" "${WIFI_IP}"; then
    UNSUPPORTED_CAPTIVE=1
    write_status "skipped_unsupported_captive_portal"
    log "Captive check failed, but response did not match supported Wi2/USEN portal markers. Skipping automation. ssid=${SSID:-unknown} ip=${WIFI_IP:-unknown}"
    rm -f "${response_headers}" "${response_body}"
    return 0
  fi

  if [[ "${response_matches_target}" != "1" ]]; then
    log "Captive check failed on target-like Wi2 network but response did not match known portal markers. Trying portal flow anyway. ssid=${SSID:-unknown} ip=${WIFI_IP:-unknown}"
  fi

  if [[ -z "${location}" ]]; then
    location="$(grep -Eho 'https?://[^"<>[:space:]]+' "${response_headers}" "${response_body}" 2>/dev/null | grep -Em 1 '(service\.wi2\.ne\.jp|10\.1\.1\.100)' || true)"
  fi
  [[ -n "${location}" ]] || location="${CAPTIVE_CHECK_URL}"
  PORTAL_DETECTED=1
  PORTAL_LOCATION="${location}"
  print -r -- "${location}" > "${LAST_PORTAL_FILE}"

  write_status "portal_detected" "${location}"
  if portal_is_usen_local "${location}"; then
    log "Detected Tully's/USEN local captive portal redirect. Trying local API first, then native captive popup fallback. ssid=${SSID:-unknown} location=${location}"
  else
    log "Detected captive portal redirect. Trying direct login. ssid=${SSID:-unknown} location=${location}"
  fi
  notify progress

  if portal_is_usen_local "${location}"; then
    BROWSER_RESULT="skipped_usen_native"
    if usen_direct_accept "${location}"; then
      rm -f "${response_headers}" "${response_body}"
      return 0
    fi
    log "Skipping headless browser for Tully's/USEN local portal because USPOT-02 renders blank there. Opening native captive popup fallback. ssid=${SSID:-unknown} location=${location}"
    open_native_portal "${location}"
    rm -f "${response_headers}" "${response_body}"
    wait_for_captive_window 20 >/dev/null 2>&1 || true
    return 0
  fi

  if [[ -x "${BROWSER_ACCEPT_HELPER}" ]] && command -v node >/dev/null 2>&1; then
    mkdir -p "${BROWSER_CAPTURE_DIR}"
    if browser_output="$(AUTO_WI2_CAPTURE_DIR="${BROWSER_CAPTURE_DIR}" node "${BROWSER_ACCEPT_HELPER}" "${location}" 2>&1)"; then
      BROWSER_RESULT="clicked"
      print -r -- "${browser_output}" > "${LAST_BROWSER_RESULT_FILE}"
      sleep 3
      if online_check_success; then
        DIRECT_ACCEPTED=1
        log "Browser automation cleared captive portal. ssid=${SSID:-unknown} ip=${WIFI_IP:-unknown} output=${browser_output}"
        write_status "browser_accept_success" "${location}"
        notify success
        rm -f "${response_headers}" "${response_body}"
        return 0
      fi
      log "Browser automation clicked but captive check still fails. ssid=${SSID:-unknown} output=${browser_output} last_result=${LAST_BROWSER_RESULT_FILE} capture_dir=${BROWSER_CAPTURE_DIR}"
    else
      if print -r -- "${browser_output}" | grep -Eq 'net::ERR_(INTERNET_DISCONNECTED|NETWORK_CHANGED|ADDRESS_UNREACHABLE|CONNECTION_REFUSED|CONNECTION_RESET|TIMED_OUT)'; then
        BROWSER_RESULT="network_error"
        if portal_is_usen_local "${location}"; then
          log "Browser automation could not route to Tully's/USEN local portal. Switching to native captive popup. ssid=${SSID:-unknown} output=${browser_output} last_result=${LAST_BROWSER_RESULT_FILE}"
        else
          log "Browser automation hit a network error. Falling back to native captive popup. ssid=${SSID:-unknown} output=${browser_output} last_result=${LAST_BROWSER_RESULT_FILE}"
        fi
      else
        BROWSER_RESULT="failed"
        log "Browser automation failed. ssid=${SSID:-unknown} output=${browser_output} last_result=${LAST_BROWSER_RESULT_FILE} capture_dir=${BROWSER_CAPTURE_DIR}"
      fi
      print -r -- "${browser_output}" > "${LAST_BROWSER_RESULT_FILE}"
    fi
  fi

  if [[ "${BROWSER_RESULT}" != "network_error" ]] && curl -L --silent --show-error --connect-timeout 3 --max-time 15 \
    --cookie-jar /tmp/auto-wi2-cookies.txt \
    --cookie /tmp/auto-wi2-cookies.txt \
    --output /tmp/auto-wi2-direct-login.html \
    "${location}" >/dev/null 2>&1; then
    sleep 3
    if online_check_success; then
      DIRECT_ACCEPTED=1
      log "Direct login cleared captive portal. ssid=${SSID:-unknown} ip=${WIFI_IP:-unknown}"
      write_status "direct_login_success" "${location}"
      notify success
      rm -f "${response_headers}" "${response_body}"
      return 0
    fi
  fi

  if [[ "${BROWSER_RESULT}" == "network_error" ]]; then
    log "Skipped curl direct login after browser network error. Opening native portal UI. ssid=${SSID:-unknown} location=${location}"
  else
    log "Direct login did not clear captive portal. Opening portal UI. ssid=${SSID:-unknown} location=${location}"
  fi
  open_native_portal "${location}"

  rm -f "${response_headers}" "${response_body}"
  wait_for_captive_window 10 >/dev/null 2>&1 || sleep 3
}

refresh_saved_login_if_due() {
  local now last_refresh age location

  [[ -f "${LAST_PORTAL_FILE}" ]] || return 0
  location="$(cat "${LAST_PORTAL_FILE}" 2>/dev/null || true)"
  [[ "${location}" == https://service.wi2.ne.jp/* ]] || return 0
  if [[ -n "${WIFI_IP:-}" && "${location}" == *"ip="* && "${location}" != *"ip=${WIFI_IP}"* ]]; then
    log "Skipping stale saved Wi2 login URL for a different IP. ssid=${SSID:-unknown} ip=${WIFI_IP:-unknown} location=${location}"
    return 0
  fi

  now="$(date +%s)"
  last_refresh="$(cat "${LAST_REFRESH_FILE}" 2>/dev/null || print 0)"
  age=$((now - last_refresh))
  [[ "${age}" -ge 1500 ]] || return 0

  if curl -L --silent --show-error --connect-timeout 3 --max-time 12 \
    --cookie-jar /tmp/auto-wi2-cookies.txt \
    --cookie /tmp/auto-wi2-cookies.txt \
    --output /tmp/auto-wi2-refresh.html \
    "${location}" >/dev/null 2>&1; then
    print -r -- "${now}" > "${LAST_REFRESH_FILE}"
    REFRESHED_SAVED_LOGIN=1
    log "Refreshed saved Wi2 login URL. ssid=${SSID:-unknown} ip=${WIFI_IP:-unknown}"
    write_status "refreshed_saved_login" "${location}"
  fi
}

SSID="$(current_ssid || true)"
WIFI_IP="$(current_wifi_ip || true)"
load_config
AUTO_WI2_BIRTH_YEAR="${AUTO_WI2_BIRTH_YEAR:-1990}"
AUTO_WI2_GENDER="${AUTO_WI2_GENDER:-Male}"
export AUTO_WI2_BIRTH_YEAR AUTO_WI2_GENDER

if online_check_success; then
  refresh_saved_login_if_due || true
  if [[ "${REFRESHED_SAVED_LOGIN}" != "1" ]]; then
    write_status "online_no_captive"
  fi
  exit 0
fi

open_portal_if_needed

if [[ "${UNSUPPORTED_CAPTIVE}" == "1" ]]; then
  exit 0
fi

if [[ "${DIRECT_ACCEPTED}" == "1" ]]; then
  exit 0
fi

if ! wait_for_captive_window 20; then
  if [[ "${PORTAL_DETECTED}" == "1" ]]; then
    write_status "portal_detected_but_no_window" "${PORTAL_LOCATION}"
    notify fail "Found the portal, but no sign-in window appeared."
  else
    write_status "no_portal_window"
  fi
  exit 0
fi

export AUTO_WI2_PORTAL_DETECTED="${PORTAL_DETECTED}"
export AUTO_WI2_BROWSER_RESULT="${BROWSER_RESULT}"
export AUTO_WI2_PORTAL_LOCATION="${PORTAL_LOCATION}"
if ! RESULT="$(osascript 2>&1 <<'APPLESCRIPT'
set clicked to false
set matched to false
set portalWasDetected to ((system attribute "AUTO_WI2_PORTAL_DETECTED") is "1")
set portalLocation to (system attribute "AUTO_WI2_PORTAL_LOCATION")
set browserResult to (system attribute "AUTO_WI2_BROWSER_RESULT")
set birthYear to (system attribute "AUTO_WI2_BIRTH_YEAR")
set genderValue to (system attribute "AUTO_WI2_GENDER")
if birthYear is missing value or birthYear is "" then set birthYear to "1990"
if genderValue is missing value or genderValue is "" then set genderValue to "Male"
set usenNativeFlow to false
if portalLocation is not missing value and portalLocation contains "10.1.1.100" then set usenNativeFlow to true
if browserResult is "skipped_usen_native" then set usenNativeFlow to true

on textContainsAny(haystack, needles)
  repeat with needle in needles
    if haystack contains (needle as text) then return true
  end repeat
  return false
end textContainsAny

on lowerText(valueText)
  set upperChars to "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
  set lowerChars to "abcdefghijklmnopqrstuvwxyz"
  set outputText to ""
  repeat with charIndex from 1 to length of valueText
    set currentChar to character charIndex of valueText
    set foundIndex to offset of currentChar in upperChars
    if foundIndex is 0 then
      set outputText to outputText & currentChar
    else
      set outputText to outputText & character foundIndex of lowerChars
    end if
  end repeat
  return outputText
end lowerText

on genderSearchText(genderValue)
  set normalizedGender to my lowerText(genderValue as text)
  if normalizedGender starts with "f" or normalizedGender contains "female" or normalizedGender contains "女性" then
    return "Female"
  end if
  return "Male"
end genderSearchText

on clickWindowRatio(windowPosition, windowSize, xRatio, yRatio)
  set clickX to (item 1 of windowPosition) + ((item 1 of windowSize) * xRatio)
  set clickY to (item 2 of windowPosition) + ((item 2 of windowSize) * yRatio)
  tell application "System Events"
    click at {clickX as integer, clickY as integer}
  end tell
end clickWindowRatio

on selectPopupAtRatio(windowPosition, windowSize, xRatio, yRatio, searchText)
  tell application "System Events"
    my clickWindowRatio(windowPosition, windowSize, xRatio, yRatio)
    delay 0.25
    keystroke (searchText as text)
    delay 0.15
    key code 36
    delay 0.25
  end tell
end selectPopupAtRatio

on runUsenNativeFlow(windowRef, birthYear, genderValue)
  try
    set windowPosition to position of windowRef
    set windowSize to size of windowRef
    my selectPopupAtRatio(windowPosition, windowSize, 0.34, 0.52, birthYear)
    my selectPopupAtRatio(windowPosition, windowSize, 0.66, 0.52, my genderSearchText(genderValue))
    my clickWindowRatio(windowPosition, windowSize, 0.5, 0.69)
    delay 2
    my clickWindowRatio(windowPosition, windowSize, 0.5, 0.27)
    return true
  end try
  return false
end runUsenNativeFlow

set targetNeedles to {"DOUTOR_FREE_Wi-Fi", "at_STARBUCKS_Wi2", "tullys_Wi-Fi", "service.wi2.ne.jp", "10.1.1.100", "Wi2 Free Wi-Fi Service", "USEN Free Wi-Fi", "USEN CORPORATION"}
set buttonLabels to {"Accept", "Connect", "Connect to the internet", "Continue to proceed", "Agree", "Next", "Start", "同意する", "接続", "次へ", "開始"}

tell application "System Events"
  repeat with passIndex from 1 to 6
    set clickedThisPass to false
    repeat with processName in {"Captive Network Assistant", "CaptiveNetworkAssistant"}
      set processNameText to processName as text
      if exists process processNameText then
        tell process processNameText
          repeat with windowRef in windows
            set windowText to ""
            try
              set windowText to name of windowRef as text
            end try

            set titleMatched to my textContainsAny(windowText, targetNeedles)
            if titleMatched or portalWasDetected then
              set matched to true
              if usenNativeFlow and passIndex is less than or equal to 3 then
                if my runUsenNativeFlow(windowRef, birthYear, genderValue) then
                  set clicked to true
                  set clickedThisPass to true
                end if
              end if
              repeat with buttonLabel in buttonLabels
                if clickedThisPass is false then
                  try
                    click button (buttonLabel as text) of windowRef
                    set clicked to true
                    set clickedThisPass to true
                  end try
                end if
              end repeat
              if clickedThisPass is false then
                try
                  set windowPosition to position of windowRef
                  set windowSize to size of windowRef
                  if usenNativeFlow then
                    if passIndex mod 2 is 1 then
                      my clickWindowRatio(windowPosition, windowSize, 0.5, 0.69)
                    else
                      my clickWindowRatio(windowPosition, windowSize, 0.5, 0.27)
                    end if
                  else
                    my clickWindowRatio(windowPosition, windowSize, 0.575, 0.76)
                  end if
                  set clicked to true
                  set clickedThisPass to true
                end try
              end if
            end if
          end repeat
        end tell
      end if
    end repeat
    if clickedThisPass then delay 2
  end repeat
end tell

if clicked then
  return "clicked"
else if matched then
  return "matched_no_button"
else
  return "no_match"
end if
