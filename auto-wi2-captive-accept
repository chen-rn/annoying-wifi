)"; then
  RESULT_DETAIL="$(print -r -- "${RESULT}" | tr '\n' ' ' | sed -E 's/[[:space:]]+/ /g' | cut -c 1-240)"
  log "Native captive popup automation failed. ssid=${SSID:-unknown} browser_result=${BROWSER_RESULT} error=${RESULT_DETAIL}"
  if print -r -- "${RESULT}" | grep -q -- "-25211"; then
    write_status "native_popup_needs_accessibility_permission" "${RESULT_DETAIL}"
    notify fail "Grant Accessibility permission so it can tap the portal." \
      "x-apple.systempreferences:com.apple.preference.security?Privacy_Accessibility"
  else
    write_status "native_popup_automation_failed" "${RESULT_DETAIL}"
    notify fail "Could not tap the captive portal automatically."
  fi
  exit 0
fi

case "${RESULT}" in
  clicked)
    sleep 4
    if online_check_success; then
      log "Native captive popup cleared Wi2 captive portal. ssid=${SSID:-unknown} browser_result=${BROWSER_RESULT}"
      write_status "native_popup_success" "browser_result=${BROWSER_RESULT}"
      notify success
    else
      log "Native captive popup clicked Wi2 captive portal but captive check still fails. ssid=${SSID:-unknown} browser_result=${BROWSER_RESULT}"
      write_status "native_popup_still_captive" "browser_result=${BROWSER_RESULT}"
      notify fail "Tapped Accept, but the network still looks blocked."
    fi
    ;;
  matched_no_button)
    log "Matched Wi2 captive portal but no Accept button was available. ssid=${SSID:-unknown}"
    write_status "matched_no_button"
    ;;
  *)
    write_status "${RESULT}"
    ;;
esac
